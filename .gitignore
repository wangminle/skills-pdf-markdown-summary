### Simplified Python project ignores

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Packaging
build/
dist/
*.egg-info/
*.egg
wheels/

# Logs and caches
.cache/
.pytest_cache/
.ruff_cache/
pip-log.txt
pip-delete-this-directory.txt

# Coverage / test
.coverage
.coverage.*
htmlcov/
coverage.xml

# mypy / type checkers
.mypy_cache/
.pytype/
.pyre/

# Jupyter
.ipynb_checkpoints/

# Editors / tools
.cursorignore
.cursorindexingignore
.pypirc
.claude/
node_modules/
**/.DS_Store

# Windows 系统缓存
Thumbs.db
ehthumbs.db
desktop.ini

# 编辑器临时/备份文件
*.swp
*.swo
*~

# 环境变量与密钥（避免泄露）
.env
.env.*

# Project specific
docs/_build/
__pypackages__/
cython_debug/

# Test results (提取脚本输出，不上传 GitHub)
tests/results/

# Benchmark 输入数据 (tests/basic-benchmark/) 为测试输入 PDF，已纳入版本控制，不忽略
